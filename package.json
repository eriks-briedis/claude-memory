{
  "name": "@briedis/claude-memory",
  "version": "0.6.2",
  "description": "Per-project memory wiki for Claude Code, driven by hooks and a nightly compiler.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriks-briedis/claude-memory.git"
  },
  "homepage": "https://github.com/eriks-briedis/claude-memory#readme",
  "bugs": {
    "url": "https://github.com/eriks-briedis/claude-memory/issues"
  },
  "type": "module",
  "bin": {
    "claude-memory": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-fuzzy": "^1.12.0",
    "micromatch": "^4.0.5",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
