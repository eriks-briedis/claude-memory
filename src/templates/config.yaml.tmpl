project:
  id: {{project_id}}
  memory_enabled: true
  # When true, the session-end hook detaches a `claude-memory compile` process
  # so the wiki stays fresh without manual runs. Set false to disable.
  auto_compile: true

retrieval:
  always_read:
    - wiki/index.md
    - wiki/project/overview.md
    - wiki/project/conventions.md
    - wiki/current/pinned.md
    - wiki/current/active-work.md
  max_context_tokens: 8000
  # Set to true to surface the retrieval summary as a system message in the TUI.
  show_breadcrumb: false

modules:
  example:
    aliases:
      - example module
      - example
    wiki_path: wiki/modules/example
    owned_paths:
      - src/example/**
    related_cross_cutting: []
